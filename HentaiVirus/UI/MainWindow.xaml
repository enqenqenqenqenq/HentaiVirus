<Window x:Class="HentaiVirus.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HentaiVirus - Установка" Height="250" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Name="InstructionText"
                       Text="Учебный симулятор: приложение покажет цикл обработки задач и логирование. Никакие программы не будут скачаны или запущены."
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,20"
                       FontWeight="Bold"
                       FontSize="14"/>

            <Button Name="AcceptButton"
                    Content="Запустить симуляцию"
                    Width="200"
                    Height="40"
                    Click="AcceptButton_Click"
                    Background="#0078D7"
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
